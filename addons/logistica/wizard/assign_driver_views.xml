<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assign_driver_wizard_form" model="ir.ui.view">
        <field name="name">assign.driver.wizard.form</field>
        <field name="model">assign.driver.wizard</field>
        <field name="arch" type="xml">
            <form string="Asignar Chofer y Vehículo">
                <group>
                    <field name="driver_id"/>
                    <field name="vehicle_id"/>
                </group>
                <footer>
                    <button name="action_assign" string="Asignar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_assign_driver_wizard" model="ir.actions.act_window">
        <field name="name">Asignar Chofer Masivo</field>
        <field name="res_model">assign.driver.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_logistics_shipment"/>
    </record>
</odoo>